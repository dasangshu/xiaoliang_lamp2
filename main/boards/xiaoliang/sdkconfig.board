# ESP32-P4 + ESP32-C5 (esp-hosted SDIO) board overrides
CONFIG_SLAVE_IDF_TARGET_ESP32C6=n
CONFIG_SLAVE_IDF_TARGET_ESP32C5=y
CONFIG_SPIRAM_TRY_ALLOCATE_WIFI_LWIP=n
CONFIG_SPIRAM_MALLOC_RESERVE_INTERNAL=98304
CONFIG_WIFI_RMT_STATIC_RX_BUFFER_NUM=6
CONFIG_WIFI_RMT_DYNAMIC_RX_BUFFER_NUM=16
CONFIG_WIFI_RMT_STATIC_TX_BUFFER_NUM=6
CONFIG_WIFI_RMT_IRAM_OPT=n
CONFIG_WIFI_RMT_RX_IRAM_OPT=n
# Disable hosted BT to free C5 slave memory for Wi-Fi (5G dual-band)
CONFIG_ESP_HOSTED_ENABLE_BT_BLUEDROID=n
CONFIG_BT_ENABLED=n
# P4+C5 hosted: internal DMA heap too tight for HW JPEG after WiFi init; SW encoder works fine
CONFIG_XIAOZHI_ENABLE_HARDWARE_JPEG_ENCODER=n
